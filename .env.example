# Copy this file to .env and fill in real values. Never commit .env.

# --- Snowflake ---
SNOWFLAKE_ACCOUNT=your-account-locator        # e.g. zjsrpzl-ekb07082
SNOWFLAKE_USER=your-username
SNOWFLAKE_PASSWORD=your-password
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=TTC_ANALYTICS
SNOWFLAKE_SCHEMA=RAW

# --- TTC ingestion ---
TTC_VEHICLE_FEED_URL=https://retro.umoiq.com/service/publicJSONFeed?command=vehicleLocations&a=ttc
RAW_DATA_DIR=/opt/airflow/data/raw

# --- Airflow ---
# UID is used by docker-compose to avoid root-owned files on the host.
# Run `id -u` on macOS/Linux and paste the number here. 50000 is the Airflow default.
AIRFLOW_UID=50000
