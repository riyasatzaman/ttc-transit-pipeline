# Copy this file to .env and fill in real values. Never commit .env.

# --- Snowflake ---
SNOWFLAKE_ACCOUNT=your-account-locator        # e.g. zjsrpzl-ekb07082
SNOWFLAKE_USER=your-username
SNOWFLAKE_PASSWORD=your-password
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=TTC_ANALYTICS
SNOWFLAKE_SCHEMA=RAW

# --- TTC ingestion ---
TTC_VEHICLE_FEED_URL=https://retro.umoiq.com/service/publicJSONFeed?command=vehicleLocations&a=ttc
# RAW_DATA_DIR is intentionally NOT set here. Leave it unset so:
#   - host runs land raw files in ./data/raw (relative to cwd)
#   - Airflow container runs use the /opt/airflow/data/raw default from docker-compose.yml
# Set it only if you want to override either path explicitly.

# --- Airflow ---
# Leave this as 50000 (the airflow user inside the image). Overriding with your
# host uid would break the user-local Python install (`import airflow` fails).
# On Docker Desktop for Mac, bind-mount file ownership is virtualized anyway,
# so there's no benefit to changing it.
AIRFLOW_UID=50000
